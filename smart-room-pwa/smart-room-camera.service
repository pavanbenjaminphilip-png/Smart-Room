[Unit]
Description=Smart Room Camera Detection
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=RP_USER
WorkingDirectory=RP_PATH
ExecStart=/usr/bin/python3 RP_PATH/camera_detection_headless.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Environment
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target
